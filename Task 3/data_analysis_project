import pandas as pd
import matplotlib.pyplot as plt

# Load CSV
df = pd.read_csv("student_data.csv")

print("Original Dataset:")
print(df)

# Check missing values
print("\nMissing Values:")
print(df.isnull().sum())

# Clean missing values
df["Marks"] = df["Marks"].fillna(df["Marks"].mean())
df["Attendance"] = df["Attendance"].fillna(df["Attendance"].mean())

# Remove duplicate rows
df = df.drop_duplicates()

print("\nSummary Statistics:")
print(df.describe())

# Filter students with marks above 80
print("\nStudents with Marks > 80:")
print(df[df["Marks"] > 80])

# Group by Department
print("\nAverage Marks by Department:")
dept = df.groupby("Department")["Marks"].mean()
print(dept)

# Save cleaned dataset
df.to_csv("cleaned_student_data.csv", index=False)

# Graph 1
dept.plot(kind="bar", title="Average Marks by Department")
plt.xlabel("Department")
plt.ylabel("Average Marks")
plt.tight_layout()
plt.savefig("department_average_marks.png")
plt.show()

# Graph 2
df["Department"].value_counts().plot(kind="pie", autopct="%1.1f%%")
plt.title("Students by Department")
plt.ylabel("")
plt.tight_layout()
plt.savefig("department_distribution.png")
plt.show()

print("\nData Analysis Completed Successfully!")
